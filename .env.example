# Database Configuration
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/family_funds?schema=public"
DIRECT_URL="postgresql://postgres:postgrespassword@localhost:5432/family_funds?schema=public"

# Clerk Authentication (OIDC)
# Leave these empty for Mock Auth mode (local development without Clerk).
# Set both to enable Clerk authentication.
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NUXT_CLERK_SECRET_KEY=""
NUXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NUXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NUXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Clerk Webhook Secret (required in Clerk mode for user sync)
# Get this from your Clerk Dashboard > Webhooks > Signing Secret
NUXT_CLERK_WEBHOOK_SIGNING_SECRET=""

# Session-Cookie HMAC-Secret (min. 32 Zeichen, REQUIRED in production).
# Wird zur HMAC-SHA256-Signierung der `__Host-session`-Cookie im Mock-Auth-
# Modus verwendet. Generiere z. B. mit:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
NUXT_SESSION_SECRET=""
