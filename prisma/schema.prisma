datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MEMBER
}

enum Frequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONCE
}

model User {
  id           String            @id @default(uuid())
  oidcSubject  String            @unique // ID from Clerk
  email        String
  displayName  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  HouseholdMember[]
  householdInvitations HouseholdInvitation[] @relation("UserHouseholdInvitations")
  expenses     ExpenseTransaction[]
  incomes      IncomeTransaction[]
  // Onboarding-Tour-State (issue #16). Per-User, nicht per-Household,
  // weil ein User mehrere Haushalte haben kann und der Onboarding-Flow
  // sich auf den User bezieht, nicht auf den Haushalt-Kontext.
  // completedSteps: Array von Step-IDs ('household' | 'invite' | 'budget' | 'transaction').
  // skipped: User hat explizit "Setup später" gewählt → kein Auto-Trigger mehr.
  onboardingCompletedSteps String[] @default([])
  onboardingSkipped        Boolean  @default(false)
}

model Household {
  id                 String               @id @default(uuid())
  name               String
  currency           String               @default("EUR") // default currency, e.g. "EUR", "USD", "CHF"
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            HouseholdMember[]
  invitations        HouseholdInvitation[]
  budgets            Budget[]
  incomePlans        IncomePlan[]
  fixedCosts         FixedCostPlan[]
  expenses           ExpenseTransaction[]
  incomeTransactions IncomeTransaction[]
  savingsGoals       SavingsGoal[]
}

model HouseholdInvitation {
  id              String      @id @default(uuid())
  householdId     String
  email           String
  role            Role        @default(MEMBER)
  invitedByUserId  String
  acceptedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  household       Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy       User        @relation("UserHouseholdInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([householdId, email])
  @@index([email])
}

model HouseholdMember {
  id           String            @id @default(uuid())
  userId       String
  householdId  String
  role         Role              @default(MEMBER)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
}

model Budget {
  id           String            @id @default(uuid())
  householdId  String
  key          String
  name         String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  versions     BudgetVersion[]
  expenses     ExpenseTransaction[]

  @@unique([householdId, key])
  @@index([householdId, key])
}

model BudgetVersion {
  id           String            @id @default(uuid())
  budgetId     String
  amount       Int               // Cent value
  frequency    Frequency
  validFrom    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  budget       Budget            @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, validFrom])
  @@index([budgetId, validFrom])
  @@index([validFrom])
}

model IncomePlan {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  amount       Int               // Cent value
  frequency    Frequency         @default(MONTHLY)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model FixedCostPlan {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  amount       Int               // Cent value
  frequency    Frequency         @default(MONTHLY)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model ExpenseTransaction {
  id           String            @id @default(uuid())
  householdId  String
  budgetId     String?
  userId       String
  amount       Int               // Cent value
  description  String?
  date         DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  budget       Budget?           @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite-Indizes fuer Hot-Path-Queries (Dashboard-Month-Window +
  // Budget-Overview). Beide haben `where: { householdId, date: { gte, lt } }`
  // + `orderBy: { date: 'desc' }`. Ohne Index macht Postgres Seq-Scan +
  // Sort. Mit `(householdId, date DESC)`-Index: Index-Scan in korrektem
  // Sort, skaliert linear mit Household-Volumen.
  @@index([householdId, date(sort: Desc)])
  @@index([budgetId, date(sort: Desc)])
}

model IncomeTransaction {
  id           String            @id @default(uuid())
  householdId  String
  userId       String
  amount       Int               // Cent value
  description  String?
  date         DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, date(sort: Desc)])
}

model SavingsGoal {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  targetAmount Int               // Cent value
  monthlyRate  Int               // Planned savings per month in Cents
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  executions   SavingsGoalExecution[]
}

model SavingsGoalExecution {
  id            String            @id @default(uuid())
  savingsGoalId String
  amount        Int               // Cent value actually saved in this month/period
  date          DateTime          // Represents which month/date this execution is for
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  savingsGoal   SavingsGoal       @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
}
