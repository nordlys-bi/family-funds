datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MEMBER
}

enum Frequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONCE
}

model User {
  id           String            @id @default(uuid())
  oidcSubject  String            @unique // ID from Clerk
  email        String
  displayName  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  HouseholdMember[]
  householdInvitations HouseholdInvitation[] @relation("UserHouseholdInvitations")
  expenses     ExpenseTransaction[]
  incomes      IncomeTransaction[]
  // Onboarding-Tour-State (issue #16). Per-User, nicht per-Household,
  // weil ein User mehrere Haushalte haben kann und der Onboarding-Flow
  // sich auf den User bezieht, nicht auf den Haushalt-Kontext.
  // completedSteps: Array von Step-IDs ('household' | 'invite' | 'budget' | 'transaction').
  // skipped: User hat explizit "Setup später" gewählt → kein Auto-Trigger mehr.
  onboardingCompletedSteps String[] @default([])
  onboardingSkipped        Boolean  @default(false)
}

model Household {
  id                 String               @id @default(uuid())
  name               String
  currency           String               @default("EUR") // default currency, e.g. "EUR", "USD", "CHF"
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            HouseholdMember[]
  invitations        HouseholdInvitation[]
  budgets            Budget[]
  incomePlans        IncomePlan[]
  fixedCosts         FixedCostPlan[]
  expenses           ExpenseTransaction[]
  incomeTransactions IncomeTransaction[]
  savingsGoals       SavingsGoal[]
}

model HouseholdInvitation {
  id              String      @id @default(uuid())
  householdId     String
  email           String
  role            Role        @default(MEMBER)
  invitedByUserId  String
  acceptedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  household       Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy       User        @relation("UserHouseholdInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([householdId, email])
  @@index([email])
}

model HouseholdMember {
  id           String            @id @default(uuid())
  userId       String
  householdId  String
  role         Role              @default(MEMBER)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
}

model Budget {
  id           String            @id @default(uuid())
  householdId  String
  key          String
  name         String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  versions     BudgetVersion[]
  expenses     ExpenseTransaction[]

  @@unique([householdId, key])
  @@index([householdId, key])
}

model BudgetVersion {
  id           String            @id @default(uuid())
  budgetId     String
  amount       Int               // Cent value
  frequency    Frequency
  validFrom    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  budget       Budget            @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, validFrom])
  @@index([budgetId, validFrom])
  @@index([validFrom])
}

model IncomePlan {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  amount       Int               // Cent value
  frequency    Frequency         @default(MONTHLY)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  // Issue #59: Rueckwaerts-Pointer auf zugeordnete Buchungen, damit
  // der monatliche Coverage-Status ("X von Y bezahlt") effizient
  // aggregiert werden kann, ohne Heuristik-Matching. onDelete: SetNull
  // — Plan loeschen hebt die Verknuepfung auf, Buchungen bleiben
  // erhalten (analog zu `Budget`-Verhalten).
  transactions IncomeTransaction[]
}

model FixedCostPlan {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  amount       Int               // Cent value
  frequency    Frequency         @default(MONTHLY)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  // Issue #59: siehe IncomePlan. Rueckwaerts-Pointer fuer Coverage.
  transactions ExpenseTransaction[]
}

model ExpenseTransaction {
  id           String            @id @default(uuid())
  householdId  String
  budgetId     String?
  userId       String
  amount       Int               // Cent value
  description  String?
  date         DateTime
  // Soft-Delete (issue #58): DELETE setzt `deletedAt = now()`, Queries
  // filtern `deletedAt: null`. Audit-Trail bleibt in der DB erhalten,
  // eine "Wiederherstellung" via POST /restore setzt den Wert zurueck.
  // Variante A (soft-permanent) gewaehlt — kein Auto-Hard-Delete nach
  // Timeout, da DB-Groesse bei privater App irrelevant ist.
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  budget       Budget?           @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  // Issue #59: optionaler FK auf einen Fixkostenplan. Wird beim
  // "Als bezahlt markieren"-Flow auf der Recurring-Page gesetzt.
  // onDelete: SetNull, damit Plan-Loeschen die Verknuepfung aufhebt
  // ohne Buchung zu verlieren (analog zu Budget).
  fixedCostPlan FixedCostPlan?   @relation(fields: [fixedCostPlanId], references: [id], onDelete: SetNull)
  fixedCostPlanId String?
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite-Indizes fuer Hot-Path-Queries (Dashboard-Month-Window +
  // Budget-Overview). Beide haben `where: { householdId, date: { gte, lt } }`
  // + `orderBy: { date: 'desc' }`. Ohne Index macht Postgres Seq-Scan +
  // Sort. Mit `(householdId, date DESC)`-Index: Index-Scan in korrektem
  // Sort, skaliert linear mit Household-Volumen.
  @@index([householdId, date(sort: Desc)])
  @@index([budgetId, date(sort: Desc)])
  // Issue #59: Index fuer Coverage-Queries ("wie viele Buchungen mit
  // diesem fixedCostPlanId in Monat X?"). FK-Lookups ueber den Plan
  // sind ohne Index Full-Table-Scan.
  @@index([fixedCostPlanId, date(sort: Desc)])
  // Soft-Delete-Index: nach Soft-Delete wandert die ueberwiegende Mehrheit
  // der Queries in `where: { householdId, deletedAt: null, ... }`. Mit dem
  // existierenden `(householdId, date DESC)`-Index macht Postgres
  // Bitmap-Index-Scan + Post-Filter auf deletedAt. Der zusaetzliche
  // `(householdId, deletedAt)`-Index ist explizit dafuer gebaut, damit
  // der Post-Filter billig wird — wichtig fuer Aggregate-Queries, die
  // pro Monat ueber alle Transaktionen summieren.
  @@index([householdId, deletedAt])
}

model IncomeTransaction {
  id           String            @id @default(uuid())
  householdId  String
  userId       String
  amount       Int               // Cent value
  description  String?
  date         DateTime
  // Soft-Delete (issue #58): siehe ExpenseTransaction. Gleiche Semantik.
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  // Issue #59: optionaler FK auf einen Einnahmenplan. Wird beim
  // "Als erhalten markieren"-Flow auf der Recurring-Page gesetzt.
  // onDelete: SetNull, damit Plan-Loeschen die Verknuepfung aufhebt
  // ohne Buchung zu verlieren.
  incomePlan   IncomePlan?       @relation(fields: [incomePlanId], references: [id], onDelete: SetNull)
  incomePlanId String?
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, date(sort: Desc)])
  // Soft-Delete-Index: siehe ExpenseTransaction.
  @@index([householdId, deletedAt])
  // Issue #59: Index fuer Coverage-Queries, siehe ExpenseTransaction.
  @@index([incomePlanId, date(sort: Desc)])
}

model SavingsGoal {
  id           String            @id @default(uuid())
  householdId  String
  name         String
  targetAmount Int               // Cent value
  monthlyRate  Int               // Planned savings per month in Cents
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  household    Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  executions   SavingsGoalExecution[]
}

model SavingsGoalExecution {
  id            String            @id @default(uuid())
  savingsGoalId String
  amount        Int               // Cent value actually saved in this month/period
  date          DateTime          // Represents which month/date this execution is for
  // Optionale Notiz, z. B. "Urlaubssparen Q3" oder "Sonderausgabe".
  // Wird beim Buchen im UI erfasst (issue #38) und ist im History-View
  // (issue #39) sichtbar. Nullable, damit bestehende Buchungen und
  // Quick-Booking ohne Notiz moeglich bleiben.
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  savingsGoal   SavingsGoal       @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
}
